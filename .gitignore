**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
backend/venv/
backend/.venv/

# Django local data
backend/db.sqlite3
backend/*.sqlite3
backend/media/
backend/staticfiles/
backend/full_test_output.txt
*.log

# Environment and secrets
.env
.env.*
!.env.example
frontend/.env.local
frontend/.env.*.local
backend/.env

# Node / Next.js
node_modules/
frontend/node_modules/
.next/
frontend/.next/
out/
dist/
build/
coverage/
