_phase_backups/
_ai_exports/
_project_md_export/
backend/_ai_exports/
backend/backend_source_snapshot.md

# Archives and generated packages
*.zip
*.rar
*.7z
*.tar
*.gz
*.patch

# Postman local data
.postman/
postman/

# Temporary source copies
retoucherback/
retoucherback

# Commercial fonts
frontend/public/fonts/iransans/

# IDE
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

